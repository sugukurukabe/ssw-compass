{
  "name": "ssw-public",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SSW Compass — MCP App for Japanese SSW visa procedural information",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "biome check .",
    "ingest": "tsx scripts/ingest-sources.ts",
    "normalize:source-index": "node scripts/normalize-source-index.mjs",
    "validate:source-index": "node scripts/validate-source-index.mjs",
    "prepare:manual-sources": "node scripts/prepare-manual-sources.mjs",
    "prepare:rag": "node scripts/prepare-sources.mjs",
    "import:rag": "node scripts/import-agent-search.mjs",
    "check:submission": "node scripts/check-submission-assets.mjs",
    "check:submission:strict": "node scripts/check-submission-assets.mjs --strict",
    "smoke:mcp": "node scripts/smoke-mcp.mjs"
  },
  "keywords": [
    "mcp",
    "visa",
    "japan",
    "tokutei-ginou"
  ],
  "author": "Sugukuru Inc.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/yauzl": "^2.10.3",
    "turbo": "^2.9.0",
    "typescript": "^5.7.0",
    "yauzl": "^3.3.0"
  }
}
