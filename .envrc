# SSW Compass — direnv configuration (project-scoped env).
# Run `direnv allow` once after cloning. See docs/onboarding.md.

# Drop any project-foreign GCP SA key env var set by other repos.
# ADR-009 Bootstrap footnote: AIOS ships a GOOGLE_APPLICATION_CREDENTIALS
# pointing at vertex-express@sugukurucorpsite which has no access to
# ssw-compass-prod-494613, so we unset it before invoking Terraform.
unset GOOGLE_APPLICATION_CREDENTIALS

# Use the developer's gcloud user credentials to mint a short-lived
# access token for Terraform + other google-go-client callers.
# The token expires after ~1 hour; re-enter the directory (or run
# `direnv reload`) to refresh.
export GOOGLE_OAUTH_ACCESS_TOKEN="$(gcloud auth print-access-token 2>/dev/null || true)"

# Default GCP project for ad-hoc gcloud invocations within this repo.
export CLOUDSDK_CORE_PROJECT="ssw-compass-prod-494613"
